<!DOCTYPE html>
<html lang="de">
<head>
  <title>Kalender – LifeSync</title>
  @vite(['resources/css/calendar.css'])
</head>
<body>
<div class="app-layout">

  @!sidebar({ active: 'calendar' })

  <main class="main-content">

    <div class="page-header">
      <h1>📅 Kalender</h1>
      <a href="/focus"><button class="btn-primary">⏱️ Zum Fokus-Timer</button></a>
    </div>

    <h2 id="month-year-display" class="cal-month"></h2>

    <div class="calendar-grid">
      <div class="day-name">Mo</div>
      <div class="day-name">Di</div>
      <div class="day-name">Mi</div>
      <div class="day-name">Do</div>
      <div class="day-name">Fr</div>
      <div class="day-name">Sa</div>
      <div class="day-name">So</div>
    </div>

    <div class="calendar-grid" id="calendar-body"></div>

  </main>
</div>

<script>
  // To-Dos vom Server (Escape von '<' verhindert ein Ausbrechen aus dem <script>)
  const serverTodos = {{{ JSON.stringify(todos).replaceAll('<', '\\u003c') }}};

  // HTML escapen, damit Aufgaben-Titel kein HTML/JS einschleusen können (XSS-Schutz)
  function esc(s) {
    return String(s).replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
    })
  }

  const date = new Date()
  const currentYear = date.getFullYear()
  const currentMonth = date.getMonth()
  const todayDate = date.getDate()

  const monthNames = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember']
  document.getElementById('month-year-display').innerText = monthNames[currentMonth] + ' ' + currentYear

  const calendarBody = document.getElementById('calendar-body')
  const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate()
  const firstDay = new Date(currentYear, currentMonth, 1).getDay()
  const emptyDays = firstDay === 0 ? 6 : firstDay - 1

  let html = ''
  for (let i = 0; i < emptyDays; i++) {
    html += '<div class="day-cell empty"></div>'
  }

  for (let i = 1; i <= daysInMonth; i++) {
    const dayString = i < 10 ? '0' + i : i
    const monthString = (currentMonth + 1) < 10 ? '0' + (currentMonth + 1) : (currentMonth + 1)
    const currentDate = `${currentYear}-${monthString}-${dayString}`

    const todosForThisDay = serverTodos.filter((t) => String(t.due_date).slice(0, 10) === currentDate)
    const isToday = (i === todayDate) ? 'today' : ''

    let todoHtml = ''
    todosForThisDay.forEach((t) => {
      todoHtml += `<div class="cal-event" title="${esc(t.title)}">${esc(t.title)}</div>`
    })

    html += `
      <div class="day-cell ${isToday}">
        <div class="day-number">${i}</div>
        <div style="flex:1; overflow-y:auto;">${todoHtml}</div>
      </div>
    `
  }
  calendarBody.innerHTML = html
</script>

</body>
</html>
