<!DOCTYPE html>
<html>
<head>
  <title>Kalender</title>
  @vite(['resources/css/calendar.css'])

</head>

<body>
  <div class="calendar-page">
    <a href="/" class="back-link">&larr; Zurück zum Dashboard</a>

    <div class="calendar-shell">
      <div class="calendar-header">
        <div>
          <h1>📅 Mein Kalender</h1>
          <p>Plane Aufgaben, Termine und Deadlines im Monatsüberblick.</p>
        </div>

        <div class="month-switch">
          <button type="button" onclick="changeMonth(-1)">‹</button>
          <div id="month-year-display"></div>
          <button type="button" onclick="changeMonth(1)">›</button>
        </div>
      </div>

      <div class="calendar-layout">
        <section>
          <div class="calendar-grid">
            <div class="day-name">Mo</div>
            <div class="day-name">Di</div>
            <div class="day-name">Mi</div>
            <div class="day-name">Do</div>
            <div class="day-name">Fr</div>
            <div class="day-name">Sa</div>
            <div class="day-name">So</div>
          </div>

          <div class="calendar-days" id="calendar-body"></div>
        </section>

        <aside class="calendar-side">
          <h2>Neuer Termin</h2>

          <div class="info-box">
<p>
Hier siehst du deine Termine im Überblick.
</p>

<p>
Füge mit „Hinzufügen“ ganz einfach einen neuen Termin hinzu.
</p>

<p>
Für besonders wichtige Termine markiere diese mit „Wichtiger Termin“.🚨
</p>          </div>

          <form class="calendar-form" onsubmit="addCalendarEvent(event)">
            <input type="text" id="eventTitle" placeholder="Titel..." required>
            <input type="date" id="eventDate" required>

            <textarea id="eventNote" placeholder="Notiz dazu..."></textarea>

            <label>
              <input type="checkbox" id="eventImportant">
              🔴 Wichtiger Termin
            </label>

            <button type="submit">Hinzufügen</button>
          </form>

          <h2>Monatsübersicht</h2>

          <div class="stat-box">
            <strong id="todo-count">0</strong>
            <span>Einträge in diesem Monat</span>
          </div>

          <div class="stat-box">
            <strong id="today-label">Heute</strong>
            <span>markierter Tag</span>
          </div>

          <div class="calendar-tip">
            ✨ Tipp: Trage zuerst Deadlines und wichtige Uni-Termine ein.
          </div>
        </aside>
      </div>
    </div>
  </div>

<script>
  const serverTodos = {{{ JSON.stringify(todos) }}};

  const date = new Date();
  let currentYear = date.getFullYear();
  let currentMonth = date.getMonth();
  const todayDate = date.getDate();

  const calendarBody = document.getElementById('calendar-body');
  const monthYearDisplay = document.getElementById('month-year-display');
  const todoCount = document.getElementById('todo-count');

  const monthNames = [
    'Januar', 'Februar', 'März', 'April', 'Mai', 'Juni',
    'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'
  ];

  function loadEvents() {
    return JSON.parse(localStorage.getItem('calendarEvents')) || [];
  }

  function saveEvents(events) {
    localStorage.setItem('calendarEvents', JSON.stringify(events));
  }

  function addCalendarEvent(event) {
    event.preventDefault();

    const title = document.getElementById('eventTitle').value.trim();
    const eventDate = document.getElementById('eventDate').value;
    const note = document.getElementById('eventNote').value.trim();
    const important = document.getElementById('eventImportant').checked;

    if (!title || !eventDate) return;

    const events = loadEvents();

    events.push({
      id: Date.now().toString(),
      title: title,
      date: eventDate,
      note: note,
      important: important
    });

    saveEvents(events);

    const selectedDate = new Date(eventDate);
    currentYear = selectedDate.getFullYear();
    currentMonth = selectedDate.getMonth();

    document.getElementById('eventTitle').value = '';
    document.getElementById('eventDate').value = '';
    document.getElementById('eventNote').value = '';
    document.getElementById('eventImportant').checked = false;

    renderCalendar();
  }

  function deleteCalendarEvent(id) {
    let events = loadEvents();

    events = events.filter(function(event) {
      return event.id !== id;
    });

    saveEvents(events);
    renderCalendar();
  }

  function changeMonth(direction) {
    currentMonth += direction;

    if (currentMonth < 0) {
      currentMonth = 11;
      currentYear--;
    }

    if (currentMonth > 11) {
      currentMonth = 0;
      currentYear++;
    }

    renderCalendar();
  }

  function renderCalendar() {
    calendarBody.innerHTML = '';
    monthYearDisplay.innerText = monthNames[currentMonth] + ' ' + currentYear;

    const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
    const firstDay = new Date(currentYear, currentMonth, 1).getDay();
    const emptyDays = firstDay === 0 ? 6 : firstDay - 1;

    const savedEvents = loadEvents();
    let monthCounter = 0;

    for (let i = 0; i < emptyDays; i++) {
      calendarBody.innerHTML += `<div class="day-cell empty"></div>`;
    }

    for (let i = 1; i <= daysInMonth; i++) {
      const dayString = i < 10 ? '0' + i : i;
      const monthString = currentMonth + 1 < 10 ? '0' + (currentMonth + 1) : currentMonth + 1;
      const currentDate = `${currentYear}-${monthString}-${dayString}`;

      // Aufgaben für diesen Tag suchen
      const todosForThisDay = serverTodos.filter(t => t.due_date === currentDate);
      
      const eventsForThisDay = savedEvents.filter(e => e.date === currentDate);

      monthCounter += todosForThisDay.length + eventsForThisDay.length;

      const isToday =
        i === todayDate &&
        currentMonth === date.getMonth() &&
        currentYear === date.getFullYear()
          ? 'today'
          : '';

      let todoHtml = '';

      todosForThisDay.forEach(t => {
        todoHtml += `<div class="todo-pill">${t.title}</div>`;
      });

      eventsForThisDay.forEach(function(event) {
        todoHtml += `
          <div class="todo-pill custom-event ${event.important ? 'important-event' : ''}">
            <div>
              <strong>${event.important ? '🔴 ' : ''}${event.title}</strong>
              ${event.note ? `<small>${event.note}</small>` : ''}
            </div>

            <button class="delete-event" type="button" onclick="deleteCalendarEvent('${event.id}')">×</button>
          </div>
        `;
      });

      calendarBody.innerHTML += `
        <div class="day-cell ${isToday}">
          <div class="day-number">${i}</div>
          <div>${todoHtml}</div>
        </div>
      `;
    }

    todoCount.innerText = monthCounter;
  }

  renderCalendar();
</script>

</body>
</html>