<!DOCTYPE html>
<html lang="de">
<head>
  <title>Registrieren – LifeSync</title>
  @vite(['resources/css/base.css'])
</head>
<body>
  <div class="form-container">
    <h1>Konto erstellen</h1>
    <p class="muted">Leg dir ein LifeSync-Konto an.</p>

    <form action="/register" method="post">
      {{ csrfField() }}

      <div style="margin-bottom:14px;">
        <label for="fullName">Name</label>
        <input type="text" name="fullName" id="fullName" placeholder="Max Mustermann">
      </div>

      <div style="margin-bottom:14px;">
        <label for="email">E-Mail</label>
        <input type="email" name="email" id="email" placeholder="du@beispiel.de" required>
      </div>

      <div style="margin-bottom:14px;">
        <label for="password">Passwort (mind. 8 Zeichen)</label>
        <input type="password" name="password" id="password" required>
      </div>

      <div style="margin-bottom:18px;">
        <label for="passwordConfirmation">Passwort wiederholen</label>
        <input type="password" name="passwordConfirmation" id="passwordConfirmation" required>
      </div>

      <button type="submit" class="btn-primary" style="width:100%; justify-content:center;">Konto erstellen</button>
    </form>

    <p class="muted" style="margin-top:16px; font-size:13px;">
      Schon ein Konto? <a href="/login">Einloggen</a>
    </p>
  </div>
</body>
</html>