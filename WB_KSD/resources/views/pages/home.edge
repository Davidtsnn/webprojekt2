<!DOCTYPE html>
<html lang="de">
<head>
  <title>LifeSync – Übersicht</title>
  @vite(['resources/css/home.css'])
</head>

<body>
<div class="app-layout">
  @!sidebar({ active: 'home' })

  <main class="main-content">

    <div class="page-header">
      <h1>Mein Habit-Dashboard</h1>
      <div style="display:flex; gap:10px;">
        <a href="/calendar"><button class="btn-secondary">📅 Kalender</button></a>
        <a href="/focus"><button class="btn-primary">⏱️ Zum Fokus-Timer</button></a>
      </div>
    </div>

    <header class="topbar">
      <div class="goal-strip">
  Kleine Schritte, große Wirkung
    </header>

    <section class="hero">
      <p>DEIN TAGESPLANER</p>
      <h1>Guten Morgen, Student!</h1>
      <span>Plane deinen Tag ruhig, klar und fokussiert.</span>


      <div class="progress-container">
        <div class="progress-card">
          <div class="progress-circle habit-goal"><strong>0%</strong></div>
          <span>Gewohnheitsziel</span>
        </div>
        <div class="progress-card">
          <div class="progress-circle learning"><strong>0%</strong></div>
          <span>Lernziel</span>
        </div>
      </div>
    </section>

    <div class="dashboard-grid">

      <section id="tasks">
        <div class="section-head">
          <div>
            <h2>Fokus des Tages</h2>
            <p>Deine wichtigsten Aufgaben</p>
          </div>
          <span>{{ todos.length }} Aufgaben</span>
        </div>

        @each (todo in todos)
          <div class="task-card priority-{{ todo.priority }}">
            <form action="/todos/complete/{{ todo.id }}" method="post">
              {{ csrfField() }}
              <button type="submit" class="check-btn">{{ todo.is_completed ? '✓' : '' }}</button>
            </form>

            <div class="task-info">
              <strong class="{{ todo.is_completed ? 'completed-text' : '' }}">{{ todo.title }}</strong>
              <small class="task-category">
                {{ todo.category }}{{ todo.due_date ? ' | Frist: ' + todo.due_date : '' }}
              </small>
              @if(todo.file_path)
                <img src="{{ todo.file_path }}" class="todo-img">
              @end
            </div>

            <span class="badge">{{ todo.priority }}</span>
            <a href="/todos/edit/{{ todo.id }}" class="icon-btn">✎</a>
            <form action="/todos/delete/{{ todo.id }}" method="post">
              {{ csrfField() }}
              <button type="submit" class="icon-btn delete">⌫</button>
            </form>
          </div>
        @end
      </section>

      <aside class="right-panel" id="habits">
        <h2>Heutige Gewohnheiten</h2>
        <p class="panel-subtitle">Kleine Schritte, große Wirkung</p>

        <form action="/habits/create" method="post" class="habit-controls">
          {{ csrfField() }}
          <input type="text" name="name" placeholder="Neue Gewohnheit..." required>
          <input type="hidden" name="category" value="Allgemein">
          <button type="submit">+</button>
        </form>

        <ul class="habit-list">
          @each(habit in habits)
            <li class="habit-card {{ habit.isDoneToday ? 'habit-done' : '' }}">
              <div class="habit-info">
                <strong>{{ habit.name }}</strong>
                <small>{{ habit.category }}</small>
              </div>
              @if(habit.isDoneToday)
                <form action="/habits/log/{{ habit.id }}" method="post" style="margin:0;">
                  {{ csrfField() }}
                  <button type="submit" class="fire-badge" style="border:none; cursor:pointer;">🔥 Geschafft!</button>
                </form>
              @else
                <form action="/habits/log/{{ habit.id }}" method="post" style="margin:0;">
                  {{ csrfField() }}
                  <button type="submit" class="round-btn">✓</button>
                </form>
              @end
            </li>
          @end
        </ul>

      

        <section class="stats-card">
          <h2>Tagesstatistik</h2>
          <p>✅ Aufgaben: {{ todos.length }} insgesamt</p>
          <p id="habitStats">🌿 Gewohnheiten: 0 von 0 erledigt</p>
          <p>📚 Lernen: automatisch durch erledigte Aufgaben</p>
        </section>

        <section class="appointments">
          <h2>Anstehende Termine</h2>
          <p class="muted" style="font-size:13px;">Die nächsten 5 Termine</p>

          <div id="calendarAppointments"></div>
        </section>
      </aside>
    </div>

    <a href="#new-task" class="floating-btn">+</a>

    <section id="new-task" class="new-task-panel">
      <h2>Neue Aufgabe</h2>
      <p>Erstelle schnell eine neue Aufgabe.</p>

      <form action="/todos/create" method="post" enctype="multipart/form-data" class="todo-form">
        {{ csrfField() }}
        <input type="text" name="title" placeholder="Was ist zu tun?" required>
        <input type="date" name="due_date">
        <select name="category">
          <option value="Uni">Uni</option>
          <option value="Haushalt">Haushalt</option>
          <option value="Freizeit">Freizeit</option>
        </select>
        <select name="priority">
          <option value="Niedrig">Niedrig</option>
          <option value="Mittel">Mittel</option>
          <option value="Hoch">Hoch</option>
        </select>
        <input type="file" name="image" accept="image/*">
        <button type="submit">Hinzufügen</button>
      </form>
    </section>

  </main>
</div>

<script>
  const todoAppointments = [
    @each(todo in todos)
      @if(todo.due_date)
        {
          title: "{{ todo.title }}",
          date: "{{ String(todo.due_date).slice(0, 10) }}",
          note: "{{ todo.category }}"
        },
      @end
    @end
  ]

  function toggleHabit(event, button) {
    event.stopPropagation()
    const card = button.closest('.habit-card')
    const habitName = card.querySelector('strong').innerText
    card.classList.toggle('habit-done')

    if (card.classList.contains('habit-done')) {
      button.innerText = '✓'
      localStorage.setItem('habit-' + habitName, 'done')
    } else {
      button.innerText = '+'
      localStorage.removeItem('habit-' + habitName)
    }

    updateGoals()
  }

  function addHabit() {
    const input = document.getElementById('newHabit')
    const name = input.value.trim()
    if (!name) return

    const customHabits = JSON.parse(localStorage.getItem('customHabits')) || []

    if (!customHabits.includes(name)) {
      customHabits.push(name)
      localStorage.setItem('customHabits', JSON.stringify(customHabits))
      createCustomHabit(name)
    }

    input.value = ''
    updateGoals()
  }

  function createCustomHabit(name) {
    const container = document.getElementById('customHabits')
    const habit = document.createElement('div')
    habit.className = 'habit-card'

    habit.innerHTML = `
      <div class="habit-info">
        <strong>${name}</strong>
        <small>NEUE GEWOHNHEIT</small>
      </div>
      <button class="round-btn" type="button" onclick="toggleHabit(event, this)">+</button>
      <button class="delete-habit" type="button" onclick="removeHabit(event, this)">×</button>
    `

    container.appendChild(habit)
  }

  function removeHabit(event, button) {
    event.stopPropagation()
    const card = button.closest('.habit-card')
    const name = card.querySelector('strong').innerText

    let customHabits = JSON.parse(localStorage.getItem('customHabits')) || []
    customHabits = customHabits.filter(function (habit) {
      return habit !== name
    })

    localStorage.setItem('customHabits', JSON.stringify(customHabits))
    localStorage.removeItem('habit-' + name)
    card.remove()
    updateGoals()
  }

  function loadCustomHabits() {
    const customHabits = JSON.parse(localStorage.getItem('customHabits')) || []
    customHabits.forEach(function (name) {
      createCustomHabit(name)
    })
  }

  function loadHabits() {
    document.querySelectorAll('.habit-card').forEach(function (card) {
      const habitName = card.querySelector('strong').innerText
      const button = card.querySelector('.round-btn')

      if (localStorage.getItem('habit-' + habitName) === 'done') {
        card.classList.add('habit-done')
        if (button) button.innerText = '✓'
      }
    })
  }

  function updateGoals() {
    const habits = document.querySelectorAll('.habit-card')
    const doneHabits = document.querySelectorAll('.habit-card.habit-done')
    let habitPercent = habits.length > 0 ? Math.round((doneHabits.length / habits.length) * 100) : 0

    const habitCircle = document.querySelector('.progress-circle.habit-goal')

    if (habitCircle) {
      habitCircle.querySelector('strong').innerText = habitPercent + '%'
      habitCircle.style.background = `conic-gradient(var(--primary) ${habitPercent * 3.6}deg, var(--primary-soft) 0deg)`
    }

    const habitStats = document.getElementById('habitStats')

    if (habitStats) {
      habitStats.innerText = '🌿 Gewohnheiten: ' + doneHabits.length + ' von ' + habits.length + ' erledigt'
    }

    const tasks = document.querySelectorAll('.task-card')
    const doneTasks = document.querySelectorAll('.completed-text')
    let learningPercent = tasks.length > 0 ? Math.round((doneTasks.length / tasks.length) * 100) : 0

    const learningCircle = document.querySelector('.progress-circle.learning')

    if (learningCircle) {
      learningCircle.querySelector('strong').innerText = learningPercent + '%'
      learningCircle.style.background = `conic-gradient(var(--success) ${learningPercent * 3.6}deg, var(--success-soft) 0deg)`
    }
  }

  function loadCalendarAppointments() {
    const container = document.getElementById('calendarAppointments')
    if (!container) return

    const calendarEvents = JSON.parse(localStorage.getItem('calendarEvents')) || []

    const today = new Date()
    today.setHours(0, 0, 0, 0)

    const allAppointments = todoAppointments.concat(calendarEvents)

    const upcomingEvents = allAppointments
      .filter(function (event) {
        const eventDate = new Date(event.date)
        eventDate.setHours(0, 0, 0, 0)
        return eventDate >= today
      })
      .sort(function (a, b) {
        return new Date(a.date) - new Date(b.date)
      })
      .slice(0, 5)

    container.innerHTML = ''

    if (upcomingEvents.length === 0) {
      container.innerHTML = `
        <p class="muted" style="font-size:13px;">
          Noch keine anstehenden Termine.
        </p>
      `
      return
    }

    upcomingEvents.forEach(function (event) {
      const day = String(event.date).slice(8, 10)

      container.innerHTML += `
        <div class="appointment">
          <div class="date-box">
            <small>FÄLLIG</small>
            <strong>${day}</strong>
          </div>

          <div>
            <strong>${event.important ? '🔴 ' : ''}${event.title}</strong>
            <small>${event.note ? event.note + ' · ' : ''}${event.date}</small>
          </div>
        </div>
      `
    })
  }

  loadCustomHabits()
  loadHabits()
  updateGoals()
  loadCalendarAppointments()
</script>

</body>
</html>